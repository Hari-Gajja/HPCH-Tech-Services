/* =============================================
   HPCH TECH - Premium Portfolio Design
   ============================================= */

@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap');

/* =============================================
   DESIGN TOKENS
   ============================================= */
:root {
  /* Colors - Bold & Electric */
  --black: #000000;
  --white: #ffffff;
  --off-white: #f5f5f5;
  --gray-100: #e5e5e5;
  --gray-400: #a3a3a3;
  --gray-600: #525252;
  --gray-800: #262626;
  --gray-900: #171717;
  
  /* Accent Colors - Vibrant */
  --neon-pink: #ff0080;
  --neon-blue: #00d4ff;
  --neon-green: #00ff88;
  --neon-purple: #bf00ff;
  --neon-orange: #ff6b00;
  --neon-yellow: #ffee00;
  
  /* Gradients */
  --gradient-hero: linear-gradient(135deg, #ff0080, #7928ca, #00d4ff);
  --gradient-sunset: linear-gradient(135deg, #ff0080, #ff6b00, #ffee00);
  --gradient-ocean: linear-gradient(135deg, #00d4ff, #0070f3, #bf00ff);
  --gradient-forest: linear-gradient(135deg, #00ff88, #00d4ff, #0070f3);
  --gradient-dark: linear-gradient(180deg, #000000, #171717);
  
  /* Typography */
  --font-display: "Syne", sans-serif;
  --font-mono: "Space Mono", monospace;
  
  /* Spacing */
  --space-xs: 0.25rem;
  --space-sm: 0.5rem;
  --space-md: 1rem;
  --space-lg: 2rem;
  --space-xl: 4rem;
  --space-2xl: 8rem;
  
  /* Animation */
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-in-out-circ: cubic-bezier(0.85, 0, 0.15, 1);
  
  /* Effects */
  --blur-sm: 10px;
  --blur-md: 20px;
  --blur-lg: 40px;
  --blur-xl: 80px;
}

/* =============================================
   RESET & BASE
   ============================================= */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-display);
  background: var(--white);
  color: var(--black);
  line-height: 1.5;
  overflow-x: hidden;
  cursor: none;
}

::selection {
  background: var(--neon-pink);
  color: var(--black);
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--off-white);
}

::-webkit-scrollbar-thumb {
  background: var(--gradient-hero);
  border-radius: 4px;
}

a {
  text-decoration: none;
  color: inherit;
}

/* =============================================
   CUSTOM CURSOR
   ============================================= */
.cursor {
  position: fixed;
  width: 20px;
  height: 20px;
  border: 2px solid var(--neon-pink);
  border-radius: 50%;
  pointer-events: none;
  z-index: 999999;
  mix-blend-mode: difference;
  transition: transform 0.2s var(--ease-out-expo), 
              width 0.3s var(--ease-out-expo), 
              height 0.3s var(--ease-out-expo);
}

.cursor-follower {
  position: fixed;
  width: 8px;
  height: 8px;
  background: var(--neon-pink);
  border-radius: 50%;
  pointer-events: none;
  z-index: 999999;
  transition: transform 0.1s ease-out;
}

.cursor.hover {
  width: 60px;
  height: 60px;
  background: rgba(255, 0, 128, 0.1);
}

/* =============================================
   ANIMATED BACKGROUNDS
   ============================================= */
.bg-particles {
  position: fixed;
  inset: 0;
  z-index: -2;
  overflow: hidden;
}

.particle {
  position: absolute;
  border-radius: 50%;
  filter: blur(var(--blur-xl));
  opacity: 0.4;
}

.particle:nth-child(1) {
  width: 400px;
  height: 400px;
  background: var(--neon-pink);
  top: -200px;
  right: -100px;
}

.particle:nth-child(2) {
  width: 300px;
  height: 300px;
  background: var(--neon-blue);
  bottom: -100px;
  left: -100px;
}

.particle:nth-child(3) {
  width: 250px;
  height: 250px;
  background: var(--neon-purple);
  top: 40%;
  left: 50%;
}

.particle:nth-child(4) {
  width: 200px;
  height: 200px;
  background: var(--neon-green);
  bottom: 10%;
  right: 20%;
}

.particle:nth-child(5) {
  width: 180px;
  height: 180px;
  background: var(--neon-orange);
  top: 20%;
  left: 10%;
}

/* Grid Overlay */
.grid-lines {
  position: fixed;
  inset: 0;
  z-index: -1;
  background-image: 
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 100px 100px;
  pointer-events: none;
}

/* Noise Texture - Removed to prevent scroll glitching */

/* =============================================
   TYPOGRAPHY
   ============================================= */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-display);
  font-weight: 800;
  line-height: 0.9;
  letter-spacing: -0.03em;
  text-transform: uppercase;
}

.display-mega {
  font-size: clamp(2.5rem, 8vw, 6rem);
  line-height: 1;
}

.display-xl {
  font-size: clamp(2rem, 6vw, 4.5rem);
  line-height: 1;
}

.display-lg {
  font-size: clamp(1.75rem, 5vw, 3.5rem);
  line-height: 1.1;
}

.display-md {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
}

p {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--gray-400);
  line-height: 1.6;
}

.mono {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  letter-spacing: 0.05em;
}

/* Text Effects */
.text-gradient {
  background: var(--gradient-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  background-size: 200% 200%;
  animation: gradientShift 5s ease infinite;
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.text-outline {
  -webkit-text-stroke: 2px var(--black);
  -webkit-text-fill-color: transparent;
  transition: all 0.4s var(--ease-out-expo);
}

.text-outline:hover {
  -webkit-text-fill-color: var(--black);
}

/* =============================================
   HEADER
   ============================================= */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 0.75rem 4%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  transition: background 0.4s ease, backdrop-filter 0.4s ease;
}

.site-header.scrolled {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
}

.brand {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.logo-circle {
  width: 38px;
  height: 38px;
  background: var(--black);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 1rem;
  color: var(--white);
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out-expo);
}

.logo-circle:hover {
  transform: rotate(360deg) scale(1.1);
}

.logo-circle::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradient-hero);
  opacity: 0;
  transition: opacity 0.4s ease;
}

.logo-circle:hover::before {
  opacity: 1;
}

.logo-letter {
  position: relative;
  z-index: 1;
}

.logo-circle:hover .logo-letter {
  color: var(--white);
}

.brand-text h1 {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  font-weight: 700;
}

.brand-text p {
  font-size: 0.55rem;
  color: var(--gray-600);
  opacity: 0.8;
  text-transform: uppercase;
  letter-spacing: 0.2em;
}

/* Navigation */
.main-nav ul {
  display: flex;
  gap: 0.5rem;
  list-style: none;
}

.nav-link {
  padding: 0.5rem 1rem;
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--gray-400);
  transition: color 0.3s ease;
  position: relative;
}

.nav-link span {
  position: relative;
}

.nav-link:hover,
.nav-link.active {
  color: var(--black);
}

.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: var(--neon-pink);
  border-radius: 50%;
}

.nav-link.cta {
  color: var(--neon-pink);
  border: 1px solid var(--neon-pink);
  border-radius: 100px;
  padding: 0.5rem 1.25rem;
}

.nav-link.cta:hover {
  background: var(--neon-pink);
  color: var(--white);
}

.mobile-menu-btn {
  display: none;
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 10px;
  z-index: 1001;
}

.mobile-menu-btn span {
  width: 30px;
  height: 2px;
  background: var(--black);
  transition: all 0.4s var(--ease-out-expo);
}

.mobile-menu-btn.active span:nth-child(1) {
  transform: rotate(45deg) translate(6px, 6px);
}

.mobile-menu-btn.active span:nth-child(2) {
  opacity: 0;
  transform: translateX(-20px);
}

.mobile-menu-btn.active span:nth-child(3) {
  transform: rotate(-45deg) translate(6px, -6px);
}

/* =============================================
   SECTIONS LAYOUT
   ============================================= */
.section {
  min-height: auto;
  padding: 80px 4% 60px;
  position: relative;
  display: flex;
  align-items: center;
}

.content {
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;
}

.section-number {
  position: absolute;
  right: 4%;
  top: 50%;
  transform: translateY(-50%);
  font-family: var(--font-mono);
  font-size: clamp(4rem, 10vw, 8rem);
  font-weight: 700;
  color: rgba(0, 0, 0, 0.06);
  pointer-events: none;
  line-height: 1;
}

/* Section Labels */
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--neon-pink);
  margin-bottom: 1rem;
}

.eyebrow::before {
  content: '';
  width: 25px;
  height: 2px;
  background: var(--gradient-hero);
}

.eyebrow i {
  font-size: 0.75rem;
}

.section-header {
  margin-bottom: 2.5rem;
}

.section-header.center {
  text-align: center;
}

.section-desc {
  font-size: 0.95rem;
  max-width: 500px;
  margin-top: 1rem;
}

.section-header.center .section-desc {
  margin-left: auto;
  margin-right: auto;
}

/* =============================================
   HERO SECTION
   ============================================= */
.hero-section {
  min-height: 90vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding-top: 100px;
}

.hero-panel {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 2.5rem;
  align-items: center;
}

.hero-text {
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 100px;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1.5rem;
  backdrop-filter: blur(10px);
}

.status-dot {
  width: 10px;
  height: 10px;
  background: var(--neon-green);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
  box-shadow: 0 0 20px var(--neon-green);
}

@keyframes pulse {
  0%, 100% { 
    transform: scale(1);
    box-shadow: 0 0 20px var(--neon-green);
  }
  50% { 
    transform: scale(1.2);
    box-shadow: 0 0 40px var(--neon-green);
  }
}

.hero-title {
  margin-bottom: 2rem;
}

.hero-title .line {
  display: block;
  overflow: hidden;
}

.hero-title .line span {
  display: inline-block;
}

.hero-title .line:nth-child(1) {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
}

.hero-title .line:nth-child(2) {
  font-size: clamp(2.25rem, 5.5vw, 4rem);
  margin-left: 3%;
}

.hero-title .line:nth-child(3) {
  font-size: clamp(1.5rem, 3.5vw, 2.5rem);
  margin-left: 6%;
}

.subtitle {
  font-size: 0.95rem;
  line-height: 1.6;
  max-width: 420px;
  margin-bottom: 1.5rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* Hero Stats */
.hero-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}

.stat {
  text-align: left;
}

.stat-number {
  display: block;
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  background: var(--gradient-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.stat-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--gray-400);
  margin-top: 0.5rem;
}

/* Hero Visual */
.hero-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Hero Logo */
.hero-logo {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-logo img {
  max-width: 100%;
  width: 450px;
  height: auto;
  filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.4));
  transition: transform 0.4s var(--ease-out-expo);
}

.hero-logo img:hover {
  transform: scale(1.05);
}

/* Scroll Indicator */
.scroll-indicator {
  position: relative;
  margin-top: 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--gray-400);
}

.scroll-indicator i {
  font-size: 1rem;
  animation: scrollBounce 2s ease-in-out infinite;
}

@keyframes scrollBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(15px); }
}

/* =============================================
   BUTTONS
   ============================================= */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-radius: 100px;
  border: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-out-expo);
}

.btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: inherit;
  filter: blur(30px);
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: -1;
}

.btn:hover::before {
  opacity: 0.6;
}

.btn.primary {
  background: var(--white);
  color: var(--black);
}

.btn.primary:hover {
  transform: scale(1.05);
  box-shadow: 0 20px 60px rgba(255, 255, 255, 0.3);
}

.btn.ghost {
  background: transparent;
  color: var(--black);
  border: 2px solid var(--black);
}

.btn.ghost:hover {
  background: var(--black);
  color: var(--white);
  transform: scale(1.05);
}

.btn.icon {
  width: 42px;
  height: 42px;
  padding: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.2);
  color: var(--black);
  backdrop-filter: blur(10px);
}

.btn.icon:hover {
  background: var(--gradient-hero);
  border-color: transparent;
  transform: scale(1.1) rotate(10deg);
}

.btn.full {
  width: 100%;
}

/* =============================================
   ABOUT SECTION
   ============================================= */
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.about-cta {
  margin-top: 1.5rem;
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* About Cards */
.about-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.info-card {
  padding: 1.25rem;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 16px;
  backdrop-filter: blur(20px);
  transition: all 0.5s var(--ease-out-expo);
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--gradient-hero);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.5s var(--ease-out-expo);
}

.info-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradient-hero);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.info-card:hover {
  transform: translateY(-10px);
  border-color: rgba(255, 0, 128, 0.3);
  box-shadow: 0 30px 80px rgba(255, 0, 128, 0.15);
}

.info-card:hover::before {
  transform: scaleX(1);
}

.info-card:hover::after {
  opacity: 0.03;
}

.info-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(255, 0, 128, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  color: var(--neon-pink);
  margin-bottom: 0.75rem;
  position: relative;
  z-index: 1;
}

.info-content {
  position: relative;
  z-index: 1;
}

.info-content h4 {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--gray-400);
  margin-bottom: 0.25rem;
}

.info-content p {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--black);
  margin: 0;
}

/* =============================================
   SERVICES SECTION
   ============================================= */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 2rem;
}

.service-card {
  background: var(--white);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.5s var(--ease-out-expo);
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-hero);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.5s var(--ease-out-expo);
}

.service-card:hover::before {
  transform: scaleX(1);
}

.service-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  border-color: rgba(255, 0, 128, 0.2);
}

.service-card.featured {
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
  border: 2px solid var(--neon-pink);
  transform: scale(1.02);
}

.service-card.featured:hover {
  transform: scale(1.02) translateY(-10px);
  box-shadow: 0 20px 60px rgba(255, 0, 128, 0.2);
}

.service-card.featured * {
  color: var(--white);
}

.service-card.featured .service-features li {
  color: rgba(255, 255, 255, 0.8);
}

.service-card.featured .service-features i {
  color: var(--neon-green);
}

.featured-badge {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: var(--gradient-hero);
  color: var(--white);
  padding: 0.35rem 0.75rem;
  border-radius: 100px;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.service-icon {
  width: 60px;
  height: 60px;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(255, 0, 128, 0.1) 0%, rgba(0, 212, 255, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  transition: all 0.4s var(--ease-out-expo);
}

.service-card:hover .service-icon {
  background: var(--gradient-hero);
  transform: scale(1.1) rotate(-5deg);
}

.service-icon i {
  font-size: 1.5rem;
  background: var(--gradient-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  transition: all 0.4s ease;
}

.service-card:hover .service-icon i {
  -webkit-text-fill-color: var(--white);
  background: none;
}

.service-card h3 {
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
  color: var(--black);
}

.service-card.featured h3 {
  color: var(--white);
}

.service-card > p {
  font-size: 0.85rem;
  line-height: 1.7;
  color: var(--gray-500);
  margin-bottom: 1.25rem;
}

.service-card.featured > p {
  color: rgba(255, 255, 255, 0.7);
}

.service-features {
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.service-features li {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.8rem;
  color: var(--gray-600);
}

.service-features i {
  font-size: 0.7rem;
  color: var(--neon-green);
}

.service-cta {
  padding-top: 1rem;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.service-card.featured .service-cta {
  border-top-color: rgba(255, 255, 255, 0.1);
}

.service-price {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--neon-pink);
}

.services-footer {
  margin-top: 3rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.guarantee {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.85rem;
  color: var(--gray-500);
  padding: 0.75rem 1.5rem;
  background: rgba(0, 255, 136, 0.05);
  border: 1px solid rgba(0, 255, 136, 0.2);
  border-radius: 100px;
}

.guarantee i {
  color: var(--neon-green);
  font-size: 1rem;
}

/* Responsive Services Grid */
@media (max-width: 1024px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .service-card.featured {
    transform: none;
  }
  
  .service-card.featured:hover {
    transform: translateY(-10px);
  }
}

@media (max-width: 640px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
  
  .service-card {
    padding: 1.5rem;
  }
}

/* =============================================
   BUDGET CALCULATOR SECTION
   ============================================= */
.budget-section {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.budget-section .section-header h2,
.budget-section .section-header .display-md {
  color: #1a1a2e;
}

.budget-section .section-desc {
  color: #4a4a4a;
}

.budget-section .eyebrow {
  color: #1a1a2e;
  background: rgba(255, 0, 128, 0.1);
  border-color: rgba(255, 0, 128, 0.3);
}

.budget-calculator-container {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 3rem;
  margin-top: 3rem;
  align-items: start;
}

.budget-options {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.budget-group {
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
}

.budget-group h3 {
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.budget-group h3 i {
  color: var(--neon-pink);
  font-size: 1rem;
}

.budget-note {
  font-size: 0.85rem;
  color: #666;
  margin-bottom: 1rem;
}

/* Radio Group */
.budget-radio-group {
  display: flex;
  gap: 1rem;
}

.budget-radio-group.maintenance {
  flex-wrap: wrap;
}

.budget-radio {
  flex: 1;
  min-width: 140px;
  cursor: pointer;
}

.budget-radio input {
  display: none;
}

.budget-radio .radio-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1.25rem 1rem;
  background: rgba(255, 255, 255, 0.9);
  border: 2px solid rgba(0, 0, 0, 0.1);
  border-radius: 12px;
  transition: all 0.3s ease;
  text-align: center;
}

.budget-radio:hover .radio-content {
  border-color: rgba(255, 0, 128, 0.4);
  background: rgba(255, 0, 128, 0.05);
}

.budget-radio.selected .radio-content {
  border-color: var(--neon-pink);
  background: rgba(255, 0, 128, 0.1);
  box-shadow: 0 0 20px rgba(255, 0, 128, 0.2);
}

.radio-title {
  font-weight: 600;
  color: #1a1a2e;
  font-size: 0.95rem;
}

.radio-desc {
  font-size: 0.75rem;
  color: #666;
}

.radio-price {
  font-size: 1.1rem;
  font-weight: 700;
  color: #00a67e;
}

/* Checkbox Group */
.budget-checkbox-group {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.budget-checkbox {
  cursor: pointer;
}

.budget-checkbox input {
  display: none;
}

.budget-checkbox .checkbox-content {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.9);
  border: 2px solid rgba(0, 0, 0, 0.1);
  border-radius: 10px;
  transition: all 0.3s ease;
}

.budget-checkbox:hover .checkbox-content {
  border-color: rgba(255, 0, 128, 0.4);
  background: rgba(255, 0, 128, 0.05);
}

.budget-checkbox.selected .checkbox-content {
  border-color: var(--neon-pink);
  background: rgba(255, 0, 128, 0.1);
}

.budget-checkbox .checkbox-content i {
  font-size: 1.2rem;
  color: var(--neon-pink);
  width: 24px;
  text-align: center;
}

.checkbox-title {
  flex: 1;
  font-weight: 500;
  color: #1a1a2e;
  font-size: 0.9rem;
}

.checkbox-price {
  font-size: 0.85rem;
  font-weight: 600;
  color: #00a67e;
}

/* Counter */
.budget-counter {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.counter-btn {
  width: 40px;
  height: 40px;
  border: 2px solid rgba(0, 0, 0, 0.2);
  background: rgba(255, 255, 255, 0.9);
  border-radius: 10px;
  color: #1a1a2e;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.counter-btn:hover {
  border-color: var(--neon-pink);
  background: rgba(255, 0, 128, 0.1);
}

.counter-value {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1a1a2e;
  min-width: 50px;
  text-align: center;
}

.counter-price {
  font-size: 1rem;
  font-weight: 600;
  color: #00a67e;
  margin-left: auto;
}

/* Total Display */
.budget-total {
  position: sticky;
  top: 120px;
}

.budget-summary {
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
  border: 2px solid rgba(255, 0, 128, 0.3);
  border-radius: 20px;
  padding: 2rem;
  text-align: center;
}

.budget-summary h3 {
  font-size: 1rem;
  color: #aaa;
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.total-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.25rem;
  margin-bottom: 1rem;
}

.total-amount .currency {
  font-size: 1.5rem;
  font-weight: 600;
  color: #fff;
}

.total-amount .amount {
  font-size: 3rem;
  font-weight: 800;
  color: #fff;
}

.total-amount .suffix {
  font-size: 1.5rem;
  font-weight: 600;
  color: #fff;
}

.maintenance-note {
  font-size: 0.9rem;
  color: var(--neon-cyan);
  margin-bottom: 1.5rem;
}

.budget-includes {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  padding: 1rem;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12px;
}

.budget-includes p {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  color: #ccc;
}

.budget-includes p i {
  color: var(--neon-green);
  font-size: 0.75rem;
}

.budget-summary .btn {
  width: 100%;
  justify-content: center;
}

/* Responsive Budget Calculator */
@media (max-width: 1024px) {
  .budget-calculator-container {
    grid-template-columns: 1fr;
  }
  
  .budget-total {
    position: static;
    order: -1;
  }
}

@media (max-width: 768px) {
  .budget-checkbox-group {
    grid-template-columns: 1fr;
  }
  
  .budget-radio-group {
    flex-direction: column;
  }
  
  .budget-radio {
    min-width: auto;
  }
}

@media (max-width: 480px) {
  .budget-group {
    padding: 1rem;
  }
  
  .total-amount .amount {
    font-size: 2.5rem;
  }
}

/* =============================================
   TEAM SECTION - Editorial Style
   ============================================= */
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.team-card {
  position: relative;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 24px;
  overflow: hidden;
  min-height: 450px;
  transition: all 0.5s var(--ease-out-expo);
}

.team-card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 
    0 30px 60px rgba(0, 0, 0, 0.4),
    0 0 40px rgba(255, 0, 128, 0.1);
}

/* First team card - Founder */
.team-card:first-child {
  background: rgb(145, 113, 53);
}

.team-card:nth-child(2) {
  background: #21ac90;
}

.team-card:nth-child(3) {
  background: #434343;
}

.team-card:nth-child(4) {
  background:#0e6c3b;
}

.team-card:first-child:hover {
  box-shadow: 
    0 30px 60px rgba(0, 0, 0, 0.5),
    0 0 40px rgba(85, 107, 47, 0.4);
}

.team-card:first-child .bg-text-main {
  color: rgba(255, 255, 255, 0.25);
}

.team-card:first-child .bg-text-accent {
  color: rgba(255, 255, 255, 0.35);
}

.team-card:nth-child(2) .bg-text-main,
.team-card:nth-child(3) .bg-text-main,
.team-card:nth-child(4) .bg-text-main {
  color: rgba(255, 255, 255, 0.25);
}

.team-card:nth-child(2) .bg-text-accent,
.team-card:nth-child(3) .bg-text-accent,
.team-card:nth-child(4) .bg-text-accent {
  color: rgba(255, 255, 255, 0.35);
}

/* Background Typography */
.team-bg-text {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  pointer-events: none;
  text-align: center;
  width: 100%;
}

.bg-text-main {
  display: block;
  font-size: 30px;
  font-weight: 900;
  color: rgba(0, 0, 0, 0.08);
  letter-spacing: 0.1em;
  line-height: 0.9;
  text-transform: uppercase;
}

.bg-text-accent {
  display: block;
  font-size: clamp(4rem, 10vw, 6rem);
  font-weight: 300;
  font-style: italic;
  color: rgba(0, 0, 0, 0.15);
  letter-spacing: -0.02em;
  margin-top: -0.2em;
}

/* Decorative Circles */
.team-circle {
  position: absolute;
  top: 15%;
  right: 10%;
  width: 200px;
  height: 200px;
  border: 2px solid rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  z-index: 2;
  transition: all 0.5s ease;
}

.team-card:hover .team-circle {
  border-color: rgba(255, 0, 128, 0.3);
  transform: scale(1.1);
}

.team-circle-small {
  position: absolute;
  bottom: 30%;
  right: 15%;
  width: 20px;
  height: 20px;
  background: var(--neon-pink);
  border-radius: 50%;
  z-index: 4;
  box-shadow: 0 0 20px var(--neon-pink);
  transition: all 0.3s ease;
}

.team-card:hover .team-circle-small {
  transform: scale(1.3);
  box-shadow: 0 0 30px var(--neon-pink);
}

/* Team Image */
.team-image {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 105%;
  height: 110%;
  z-index: 3;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.team-card:first-child .team-image {
  width: 150%;
  height: 150%;
}

.team-card:nth-child(3) .team-image {
  width: 140%;
  height: 140%;
  transform: translateX(-60%);
}

.team-card:nth-child(4) .team-image {
  width: 150%;
  height: 150%;
}

.team-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: bottom center;
  filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
  transition: all 0.4s ease;
}

.team-card:hover .team-image img {
  transform: scale(1.05);
  filter: drop-shadow(0 15px 40px rgba(255, 0, 128, 0.2));
}

.team-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, transparent 0%, rgba(255, 0, 128, 0.05) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 6rem;
  color: rgba(255, 255, 255, 0.2);
  transition: all 0.4s ease;
}

.team-card:hover .team-placeholder {
  color: rgba(255, 0, 128, 0.4);
}

/* Team Info */
.team-info {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 1.5rem;
  z-index: 5;
}

.team-info h3 {
  font-size: 1.5rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.25rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.team-role {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: rgba(255, 255, 255, 0.6);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 1rem;
}

.team-discover {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  text-decoration: none;
  transition: all 0.3s ease;
}

.team-discover i {
  font-size: 0.6rem;
  transition: transform 0.3s ease;
}

.team-discover:hover {
  color: var(--neon-pink);
}

.team-discover:hover i {
  transform: translateX(5px);
}

/* Vertical Social Links */
.team-social-vertical {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  z-index: 5;
}

.team-social-vertical a {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: none;
  letter-spacing: 0.1em;
  transition: all 0.3s ease;
  writing-mode: horizontal-tb;
}

.team-social-vertical a:hover {
  color: var(--neon-pink);
  transform: translateX(-3px);
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .team-card {
    min-height: 380px;
  }
  
  .bg-text-main {
    font-size: 1.5rem;
  }
  
  .bg-text-accent {
    font-size: 2rem;
  }
  
  .team-circle {
    width: 150px;
    height: 150px;
  }
  
  .team-card:nth-child(4) .team-image {
    width: 100%;
    height: 100%;
  }
}

/* =============================================
   PROJECTS SECTION
   ============================================= */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 1.25rem;
  margin-top: 2rem;
}

.project-card {
  grid-column: span 4;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.6s var(--ease-out-expo);
  position: relative;
}

.project-card.featured {
  grid-column: span 8;
  grid-row: span 2;
}

.project-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradient-hero);
  opacity: 0;
  transition: opacity 0.5s ease;
  z-index: 1;
}

.project-card:hover {
  border-color: var(--neon-pink);
  transform: translateY(-15px);
  box-shadow: 
    0 50px 100px rgba(0, 0, 0, 0.3),
    0 30px 60px rgba(255, 0, 128, 0.2);
}

.project-card:hover::before {
  opacity: 0.05;
}

.project-image {
  position: relative;
  height: 140px;
  overflow: hidden;
}

.project-card.featured .project-image {
  height: 200px;
}

.project-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(255, 0, 128, 0.1), rgba(0, 212, 255, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.6s var(--ease-out-expo);
}

.project-card:hover .project-placeholder {
  transform: scale(1.1);
}

.project-placeholder i {
  font-size: 2.5rem;
  background: var(--gradient-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  opacity: 0.4;
}

.project-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.95));
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 2rem;
  gap: 1rem;
  opacity: 0;
  transition: opacity 0.5s ease;
  z-index: 2;
}

.project-card:hover .project-overlay {
  opacity: 1;
}

.project-link {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--black);
  font-size: 0.85rem;
  transition: all 0.4s var(--ease-out-expo);
}

.project-link:hover {
  background: var(--neon-pink);
  transform: scale(1.15);
}

.project-info {
  padding: 1.25rem;
  position: relative;
  z-index: 2;
}

.project-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
}

.project-status {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0.35rem 0.7rem;
  background: rgba(255, 0, 128, 0.15);
  color: var(--neon-pink);
  border-radius: 100px;
  white-space: nowrap;
}

.project-info h3 {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: none;
  line-height: 1.3;
  margin-bottom: 0.5rem;
  color: var(--black);
}

.project-info p {
  font-size: 0.8rem;
  margin-bottom: 0.75rem;
  color: var(--gray-600);
}

.project-features {
  list-style: none;
  margin-bottom: 0.75rem;
}

.project-features li {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: var(--gray-600);
  margin-bottom: 0.4rem;
}

.project-features i {
  color: var(--neon-green);
  font-size: 0.6rem;
  margin-top: 0.25rem;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.chip {
  padding: 0.3rem 0.6rem;
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.1);
  border-radius: 100px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--gray-600);
  transition: all 0.3s ease;
}

.chip:hover {
  background: rgba(255, 0, 128, 0.1);
  border-color: var(--neon-pink);
  color: var(--neon-pink);
}

.chip.small {
  padding: 0.25rem 0.5rem;
  font-size: 0.55rem;
}

.projects-cta {
  text-align: center;
  margin-top: 2rem;
}

/* =============================================
   EXPERIENCE/PROCESS SECTION
   ============================================= */
.experience-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.experience-column {
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 16px;
  padding: 1.5rem;
}

.column-title {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.column-title i {
  font-size: 1rem;
  background: var(--gradient-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.column-title h3 {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--black);
}

.timeline {
  position: relative;
  padding-left: 1.5rem;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(180deg, var(--neon-pink), var(--neon-purple), transparent);
  border-radius: 2px;
}

.timeline-item {
  position: relative;
  padding-bottom: 1.5rem;
}

.timeline-dot {
  position: absolute;
  left: -1.5rem;
  top: 4px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--gradient-hero);
  transform: translateX(-50%);
  box-shadow: 0 0 15px var(--neon-pink);
}

.timeline-dot::after {
  content: '';
  position: absolute;
  inset: 2px;
  background: var(--white);
  border-radius: 50%;
}

.timeline-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
}

.timeline-header h4 {
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: none;
  line-height: 1.3;
  color: var(--black);
}

.timeline-date {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--neon-pink);
  white-space: nowrap;
  padding: 0.25rem 0.5rem;
  background: rgba(255, 0, 128, 0.1);
  border-radius: 100px;
}

.timeline-company,
.timeline-location {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--gray-600);
  margin-bottom: 0.35rem;
}

.timeline-company i,
.timeline-location i {
  font-size: 0.7rem;
  width: 16px;
}

.timeline-list {
  list-style: none;
  margin-top: 0.75rem;
}

.timeline-list li {
  position: relative;
  padding-left: 1rem;
  font-size: 0.75rem;
  color: var(--gray-600);
  margin-bottom: 0.4rem;
  line-height: 1.5;
}

.timeline-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 7px;
  width: 4px;
  height: 4px;
  background: var(--gradient-hero);
  border-radius: 50%;
}

/* =============================================
   CONTACT SECTION
   ============================================= */

/* Commitment Cards */
.commitment-section {
  margin-bottom: 3rem;
}

.commitment-heading {
  font-family: var(--font-display);
  font-size: 1.35rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 1.5rem;
  color: var(--black);
  letter-spacing: -0.02em;
}

.commitment-heading i {
  color: var(--accent);
  margin-right: 0.5rem;
}

.commitment-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}

.commitment-card {
  background: var(--light);
  border: 1px solid #e8e8e8;
  border-radius: 16px;
  padding: 1.75rem 1.5rem;
  text-align: center;
  transition: all 0.35s ease;
  position: relative;
  overflow: hidden;
}

.commitment-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), #333);
  transform: scaleX(0);
  transition: transform 0.35s ease;
}

.commitment-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  border-color: #d0d0d0;
}

.commitment-card:hover::before {
  transform: scaleX(1);
}

.commitment-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: var(--black);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  margin: 0 auto 1rem;
}

.commitment-card p {
  font-family: var(--font-body);
  font-size: 0.85rem;
  line-height: 1.65;
  color: #555;
  margin: 0;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 2rem;
  margin-top: 2rem;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.contact-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 12px;
  transition: all 0.5s var(--ease-out-expo);
  text-decoration: none;
}

.contact-card:hover {
  border-color: var(--neon-pink);
  transform: translateX(8px);
  box-shadow: 0 10px 30px rgba(255, 0, 128, 0.1);
}

.contact-card .contact-icon {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: rgba(255, 0, 128, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  color: var(--neon-pink);
  flex-shrink: 0;
  transition: all 0.4s ease;
  margin-bottom: 0;
}

.contact-card:hover .contact-icon {
  background: var(--gradient-hero);
  color: var(--white);
}

.contact-details h4 {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--gray-600);
  margin-bottom: 0.2rem;
}

.contact-details p {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--black);
  margin: 0;
}

/* Contact Form */
.contact-form {
  background: rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 16px;
  padding: 1.5rem;
}

.form-message {
  padding: 1rem;
  border-radius: 10px;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.85rem;
  font-weight: 500;
}

.form-message.success {
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: #16a34a;
}

.form-message.error {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #dc2626;
}

.form-message i {
  font-size: 1.1rem;
}

.form-header {
  margin-bottom: 1.25rem;
}

.form-header h3 {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: none;
  margin-bottom: 0.35rem;
  color: var(--black);
}

.form-header p {
  font-size: 0.8rem;
  margin: 0;
  color: var(--gray-600);
}

.field {
  margin-bottom: 1rem;
}

.field label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--gray-600);
  margin-bottom: 0.5rem;
}

.field label i {
  font-size: 0.7rem;
}

.field input,
.field textarea {
  width: 100%;
  padding: 0.75rem 1rem;
  background: rgba(255, 255, 255, 1);
  border: 1px solid rgba(0, 0, 0, 0.15);
  border-radius: 10px;
  color: var(--black);
  font-family: var(--font-display);
  font-size: 0.85rem;
  transition: all 0.4s ease;
}

.field input:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--neon-pink);
  box-shadow: 0 0 0 4px rgba(255, 0, 128, 0.15);
}

.field input::placeholder,
.field textarea::placeholder {
  color: var(--gray-600);
}

.field textarea {
  resize: vertical;
  min-height: 100px;
}

/* Locked / read-only fields (auto-filled from Google) */
.field input.field-locked {
  background: rgba(240, 240, 240, 1);
  color: var(--gray-600);
  cursor: not-allowed;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.field input.field-locked:focus {
  border-color: rgba(0, 0, 0, 0.08);
  box-shadow: none;
}

/* ==============================================
   FOOTER
   ============================================= */
.site-footer {
  padding: 1.5rem 4%;
  background: rgba(240, 240, 240, 1);
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.footer-content {
  max-width: 1600px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.logo-circle.small {
  width: 30px;
  height: 30px;
  font-size: 0.8rem;
}

.footer-content > p {
  font-size: 0.75rem;
  color: var(--gray-400);
  margin: 0;
}

.footer-content > p i {
  color: var(--neon-pink);
  animation: heartbeat 1s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.footer-links {
  display: flex;
  gap: 0.5rem;
}

.footer-links a {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.03);
  border: 1px solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gray-400);
  font-size: 0.85rem;
  transition: all 0.4s var(--ease-out-expo);
}

.footer-links a:hover {
  background: var(--gradient-hero);
  border-color: transparent;
  color: var(--white);
  transform: translateY(-5px);
}

/* =============================================
   BACK TO TOP
   ============================================= */
.back-to-top {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--gradient-hero);
  border: none;
  color: var(--white);
  font-size: 1rem;
  cursor: pointer;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px) scale(0.8);
  transition: all 0.5s var(--ease-out-expo);
  z-index: 50;
  box-shadow: 0 10px 30px rgba(255, 0, 128, 0.3);
}

.back-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}

.back-to-top:hover {
  transform: translateY(-5px) scale(1.05);
}

/* =============================================
   SCROLL ANIMATIONS
   ============================================= */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-left {
  opacity: 0;
  transform: translateX(-30px);
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}

.reveal-left.visible {
  opacity: 1;
  transform: translateX(0);
}

.reveal-right {
  opacity: 0;
  transform: translateX(30px);
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}

.reveal-right.visible {
  opacity: 1;
  transform: translateX(0);
}

.reveal-scale {
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 1.2s var(--ease-out-expo), transform 1.2s var(--ease-out-expo);
}

.reveal-scale.visible {
  opacity: 1;
  transform: scale(1);
}

.delay-100 { transition-delay: 100ms !important; }
.delay-200 { transition-delay: 200ms !important; }
.delay-300 { transition-delay: 300ms !important; }
.delay-400 { transition-delay: 400ms !important; }
.delay-500 { transition-delay: 500ms !important; }

/* =============================================
   MARQUEE TEXT ANIMATION
   ============================================= */
.marquee {
  position: relative;
  overflow: hidden;
  padding: 0.75rem 0;
  background: rgba(245, 245, 245, 1);
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.marquee-content {
  display: flex;
  animation: marquee 30s linear infinite;
  white-space: nowrap;
}

.marquee-content span {
  font-family: var(--font-display);
  font-size: clamp(1rem, 3vw, 1.5rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 1rem;
  color: transparent;
  -webkit-text-stroke: 1px rgba(0, 0, 0, 0.15);
}

.marquee-content span.filled {
  -webkit-text-stroke: 0;
  background: var(--gradient-hero);
  -webkit-background-clip: text;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* Faster marquee on tablet and mobile */
@media (max-width: 1024px) {
  .marquee-content {
    animation: marquee 15s linear infinite;
  }
}

@media (max-width: 768px) {
  .marquee-content {
    animation: marquee 10s linear infinite;
  }
}

/* =============================================
   RESPONSIVE DESIGN
   ============================================= */
@media (max-width: 1200px) {
  .projects-grid {
    grid-template-columns: repeat(6, 1fr);
  }
  
  .project-card {
    grid-column: span 3;
  }
  
  .project-card.featured {
    grid-column: span 6;
    grid-row: span 1;
  }
}

@media (max-width: 1024px) {
  body {
    cursor: auto;
  }
  
  .cursor,
  .cursor-follower {
    display: none;
  }
  
  .hero-panel,
  .two-col,
  .skills-container,
  .experience-grid,
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .commitment-cards {
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  
  .hero-visual {
    order: -1;
    max-width: 350px;
    margin: 0 auto;
  }
  
  .hero-text {
    text-align: center;
  }
  
  .hero-actions {
    justify-content: center;
  }
  
  .hero-stats {
    justify-content: center;
  }
  
  .subtitle {
    margin-left: auto;
    margin-right: auto;
  }
  
  .section-number {
    display: none;
  }
  
  .hero-logo img {
    width: 350px;
  }
}

@media (max-width: 768px) {
  .section {
    padding: 70px 5% 50px;
  }
  
  .site-header {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  
  .main-nav {
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 1.5rem;
    transform: translateX(100%);
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s var(--ease-out-expo);
  }
  
  .main-nav.active {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
  }
  
  .main-nav ul {
    flex-direction: column;
    gap: 0.5rem;
    align-items: stretch;
  }
  
  .nav-link {
    display: block;
    text-align: center;
    padding: 0.85rem 1rem;
    font-size: 0.85rem;
    color: #ffffff;
    background: rgba(0, 0, 0, 0.479);
    border-radius: 10px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .nav-link:hover {
    background: rgba(0, 0, 0, 0.08);
  }
  
  .nav-link.active::after {
    display: none;
  }

  .nav-link.active {
    background: #000000;
    color: #ffffff;
  }
  
  .nav-link.cta {
    margin-top: 0.5rem;
    background: #000000;
    color: #ffffff;
  }

  .nav-link.cta:hover {
    background: #222222;
  }
  
  .mobile-menu-btn {
    display: flex;
  }
  
  .projects-grid {
    grid-template-columns: 1fr;
  }
  
  .project-card,
  .project-card.featured {
    grid-column: span 1;
  }
  
  .about-cards {
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  
  .hero-stats {
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  
  .hero-logo img {
    width: 280px;
  }
  
  .footer-content {
    flex-direction: column;
    text-align: center;
  }
  
  .stat-number {
    font-size: 1.5rem;
  }
  
  .about-cta {
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .hero-title .line:nth-child(1) {
    font-size: 1.5rem;
  }
  
  .hero-title .line:nth-child(2) {
    font-size: 2rem;
    margin-left: 0;
  }
  
  .hero-title .line:nth-child(3) {
    font-size: 1.25rem;
    margin-left: 0;
  }
  
  .hero-actions {
    flex-direction: column;
    width: 100%;
  }
  
  .hero-actions .btn:not(.icon) {
    width: 100%;
  }
  
  .hero-actions .btn.icon {
    align-self: center;
  }
  
  .skill-item {
    grid-template-columns: 24px 70px 1fr;
    gap: 0.5rem;
  }
  
  .contact-form,
  .experience-column {
    padding: 1rem;
  }
  
  .info-card {
    padding: 1rem;
  }
  
  .about-cards {
    grid-template-columns: 1fr;
  }

  .commitment-cards {
    grid-template-columns: 1fr;
  }

  .commitment-card {
    padding: 1.25rem 1rem;
  }
}

/* =============================================
   HEADER USER / LOGOUT
   ============================================= */

.header-user {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-left: 1rem;
}

.header-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.15);
  object-fit: cover;
}

.logout-btn {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  background: rgba(255, 0, 128, 0.15);
  border: 1px solid rgba(255, 0, 128, 0.35);
  padding: 0.35rem 0.8rem;
  border-radius: 999px;
  cursor: pointer;
  transition: background 0.25s, border-color 0.25s;
}

.logout-btn:hover {
  background: rgba(255, 0, 128, 0.35);
  border-color: #ff0080;
}

.header-login-btn {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  background: rgba(0, 212, 255, 0.12);
  border: 1px solid rgba(0, 212, 255, 0.35);
  padding: 0.4rem 1rem;
  border-radius: 999px;
  cursor: pointer;
  margin-left: 1rem;
  transition: background 0.25s, border-color 0.25s;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.header-login-btn:hover {
  background: rgba(0, 212, 255, 0.3);
  border-color: #00d4ff;
}

@media (max-width: 768px) {
  .header-user {
    margin-left: 0;
    margin-right: 3.5rem;
  }
  .header-login-btn {
    margin-left: 0;
    margin-right: 3.5rem;
  }
}
